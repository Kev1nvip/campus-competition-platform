# 复制本文件为 application-dev.yml
# application-dev.yml 已加入 .gitignore，不会提交到仓库
# 本文件是示例，提交到仓库供队友参考

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/campus_competition
    username: competition
    password: competition123
    driver-class-name: org.postgresql.Driver

  data:
    redis:
      host: localhost
      port: 6379
      password: redis123
      database: 0

  rabbitmq:
    host: localhost
    port: 5672
    username: competition
    password: competition123
    virtual-host: /

  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: true

logging:
  level:
    root: INFO
    com.competition: DEBUG